# InsightHub .gitignore — excludes secrets, build artifacts, and local caches.

# Environment / secrets
.env
*.env.local
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Node / React
node_modules/
frontend/build/
frontend/dist/
.next/
.nuxt/
*.log
npm-debug.log*
yarn-error.log*

# Power BI
*.pbix
*.pbids

# Azure / Terraform / Bicep
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan

# IDE
.vscode/settings.json
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
docker-compose.override.yml

# Local diagnostic / one-off scripts (never commit)
test_conn.py
check_columns.py
fix_views.py
load_campaigns_only.py
instructions.txt

# Deployment zips
*.zip
insighthub-backend.zip

# Screenshots are committed to git so GitHub README renders them
# docs/screenshots/*.png

# Internal project docs — not for public GitHub
CLAUDE.md
docs/PORTFOLIO.md
