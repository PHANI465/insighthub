# InsightHub environment variables template.
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=

# Azure SQL / Database
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Azure Blob Storage / ADLS
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
STORAGE_CONTAINER=

# Azure AI Search
AI_SEARCH_ENDPOINT=
AI_SEARCH_API_KEY=
AI_SEARCH_INDEX_NAME=

# Azure OpenAI / OpenAI
OPENAI_API_KEY=
OPENAI_ENDPOINT=
OPENAI_DEPLOYMENT_NAME=

# Power BI Embedding
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=

# Azure SQL Database (Phase 2)
DB_SERVER=insighthub-server.database.windows.net   # Azure SQL Server FQDN
DB_NAME=insighthub-db                              # Database name
DB_USER=insighthub-admin                           # SQL login username
DB_PASSWORD=                                       # SQL login password (use Key Vault in production)
DB_PORT=1433                                       # Default Azure SQL port

# ETL Pipeline (Phase 3)
ETL_CHUNK_SIZE=2000       # Rows per database commit batch (tune for memory vs. throughput)
ETL_MAX_ERRORS=500        # Abort an entity if validation rejects more than this many rows
ETL_LOG_LEVEL=INFO        # DEBUG for verbose output, INFO for normal runs

# Data Generation (Phase 1)
DATA_GENERATION_SEED=42          # Fixed seed — same seed = same CSV data every run
DATA_OUTPUT_DIR=data-generation/output  # Where CSVs are saved locally
BLOB_RAW_SUBFOLDER=raw/insighthub       # Prefix inside the blob container for raw CSVs
NUM_CUSTOMERS=10000              # Rows to generate for customers.csv
NUM_PRODUCTS=500                 # Rows to generate for products.csv
NUM_EMPLOYEES=200                # Rows to generate for employees.csv
NUM_ORDERS=50000                 # Rows to generate for orders.csv
NUM_TICKETS=20000                # Rows to generate for support_tickets.csv
NUM_CAMPAIGNS=100                # Rows to generate for campaigns.csv

# Azure AI Search (Phase 6)
AZURE_SEARCH_ENDPOINT=             # https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=                  # Admin API key from Azure Portal
AZURE_SEARCH_INDEX=insighthub-docs # Index name (default: insighthub-docs)

# Azure OpenAI (Phase 6)
AZURE_OPENAI_ENDPOINT=             # https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_KEY=                  # API key from Azure Portal
AZURE_OPENAI_DEPLOYMENT=gpt-4o     # Chat deployment name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002  # Embedding deployment name

# JWT Authentication (Phase 4)
JWT_SECRET_KEY=                    # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Power BI Embedded — App-Owns-Data service principal (Phase 5)
POWERBI_CLIENT_ID=                 # Azure AD app registration client ID
POWERBI_CLIENT_SECRET=             # Azure AD app registration client secret
POWERBI_TENANT_ID=                 # Your Azure AD tenant ID
POWERBI_WORKSPACE_ID=              # Power BI workspace (group) ID
POWERBI_REPORT_ID=                 # Power BI report ID

# Application Insights (Phase 9)
APPLICATIONINSIGHTS_CONNECTION_STRING=   # Connection string from Azure Portal

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
REACT_APP_API_BASE_URL=http://localhost:8000
