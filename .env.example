# InsightHub environment variables template.
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=

# Azure SQL / Database
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Azure Blob Storage / ADLS
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
STORAGE_CONTAINER=

# Azure AI Search
AI_SEARCH_ENDPOINT=
AI_SEARCH_API_KEY=
AI_SEARCH_INDEX_NAME=

# Azure OpenAI / OpenAI
OPENAI_API_KEY=
OPENAI_ENDPOINT=
OPENAI_DEPLOYMENT_NAME=

# Power BI Embedding
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
REACT_APP_API_BASE_URL=http://localhost:8000
