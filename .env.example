# InsightHub — environment variables template
# Copy to .env and fill in your values.  NEVER commit .env to source control.

# ── Azure SQL Database ────────────────────────────────────────────────────────
DB_SERVER=your-server.database.windows.net
DB_NAME=insighthub-db
DB_USER=your-sql-user
DB_PASSWORD=
DB_PORT=1433

# ── Azure Blob Storage / ADLS Gen2 ───────────────────────────────────────────
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
STORAGE_CONTAINER=insighthub

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=insighthub-docs

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Application Insights (optional for local dev) ─────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Azure Key Vault (optional for local dev) ──────────────────────────────────
AZURE_KEYVAULT_URL=https://your-kv.vault.azure.net/

# ── Power BI Embedded (App-Owns-Data service principal) ───────────────────────
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=

# ── Azure identifiers (for Bicep deploy) ──────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=rg-insighthub-devphani

# ── ETL settings ──────────────────────────────────────────────────────────────
ETL_CHUNK_SIZE=2000
ETL_MAX_ERRORS=500
ETL_LOG_LEVEL=INFO

# ── Data generation ───────────────────────────────────────────────────────────
DATA_GENERATION_SEED=42
NUM_CUSTOMERS=10000
NUM_PRODUCTS=500
NUM_EMPLOYEES=200
NUM_ORDERS=50000
NUM_TICKETS=20000
NUM_CAMPAIGNS=100
BLOB_RAW_SUBFOLDER=raw/insighthub

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set in frontend/.env.development and frontend/.env.production instead
# VITE_API_URL=http://localhost:8000
